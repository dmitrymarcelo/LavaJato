# Frontend
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_API_URL="/api"

# Backend
API_PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lavajato"
AUTH_SESSION_DAYS=7
TRUST_PROXY_HOPS=1
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=6
ADMIN_INITIAL_PASSWORD="Troque-esta-senha-em-producao!"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1"
ALLOWED_REMOTE_IMAGE_HOSTS="teslaeventos.com.br,images.unsplash.com,i.pravatar.cc"
